# ─── API Keys ─────────────────────────────────────────────────
# Sua API Key da Anthropic (para Claude) - OBRIGATÓRIO
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# URL do proxy gameron (coletar dados locais e enviar para Claude)
# Padrão: http://localhost:1337 (gameron local)
ANTHROPIC_BASE_URL=http://localhost:1337
ANTHROPIC_DIRECT_URL=https://api.anthropic.com

# ─── Claude Config ────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MODEL_CHAT=claude-opus-4-6
CLAUDE_MODEL_ANALYSIS=claude-sonnet-4-20250514
CLAUDE_MODEL_SIMPLE=claude-haiku-4-20250414
MAX_TOKENS=4096
TEMPERATURE=0.3
PROMPT_CACHE_ENABLED=true

# ─── Agentes ──────────────────────────────────────────────────
MAX_AGENTS=20
AGENT_TIMEOUT=300

# ─── Armazenamento ────────────────────────────────────────────
# Paths para Docker (ajustar para dev local se necessário)
UPLOAD_DIR=./data/uploads
MEDIA_DIR=./data/media
MAX_UPLOAD_SIZE=524288000
MAX_UPLOAD_SIZE_MB=500

# ─── Database ─────────────────────────────────────────────────
# Paths para Docker (ajustar para dev local se necessário)
DATABASE_URL=sqlite+aiosqlite:///./data/whatsapp_insight.db
RUN_DB_MIGRATIONS_ON_STARTUP=true

# ─── App ──────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=change-this-in-production-at-least-32-chars-long!!
DATA_RETENTION_DAYS=90
ENABLE_METRICS=true

# ─── JWT Authentication ──────────────────────────────────────
# OBRIGATÓRIO: Chave secreta para assinar tokens JWT (mínimo 32 caracteres)
JWT_SECRET_KEY=change-this-jwt-secret-in-production-min-32-chars!!
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ─── Admin User ──────────────────────────────────────────────
# OBRIGATÓRIO: Credenciais do usuário administrador
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password!!

# ─── Registration ────────────────────────────────────────────
# Permitir registro de novos usuários (true/false)
ALLOW_REGISTRATION=false

# ─── CORS (separado por vírgulas) ────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── Redis / Cache ────────────────────────────────────────────
# URL do Redis (deixe vazio para desabilitar cache)
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=change-this-redis-password
# TTL do cache em segundos (padrão: 86400 = 24h)
CACHE_TTL_SECONDS=86400
# Habilitar/desabilitar cache (true/false)
CACHE_ENABLED=true

# ─── Produção / Infra ─────────────────────────────────────────
POSTGRES_USER=wit
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=whatsapp_insight
ELASTIC_PASSWORD=change-this-elastic-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password

# ─── Nginx / SSL ─────────────────────────────────────────────────
# Arquivo de config nginx (nginx-http.conf para HTTP, nginx-https.conf para HTTPS)
NGINX_CONF_FILE=nginx-http.conf
# Domínio para certificado SSL (usado pelo certbot)
APP_DOMAIN=transcriber.jurislaw.com.br

# ─── Alertmanager ────────────────────────────────────────────────
# URL do webhook para receber alertas (Slack, Discord, Telegram, etc.)
ALERTMANAGER_WEBHOOK_URL=http://localhost:9093
ALERTMANAGER_WEBHOOK_USER=
ALERTMANAGER_WEBHOOK_PASSWORD=

# ─── Logging ──────────────────────────────────────────────────
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Formato de log: json (produção) ou console (desenvolvimento)
LOG_FORMAT=json
