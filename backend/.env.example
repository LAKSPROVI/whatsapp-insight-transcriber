# ─── API Keys ─────────────────────────────────────────────────
# Sua API Key da Anthropic (para Claude) - OBRIGATÓRIO
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# URL do proxy gameron (coletar dados locais e enviar para Claude)
# Padrão: http://localhost:1337 (gameron local)
ANTHROPIC_BASE_URL=http://localhost:1337

# ─── Claude Config ────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6
MAX_TOKENS=4096
TEMPERATURE=0.3

# ─── Agentes ──────────────────────────────────────────────────
MAX_AGENTS=20
AGENT_TIMEOUT=300

# ─── Armazenamento ────────────────────────────────────────────
# Paths para Docker (ajustar para dev local se necessário)
UPLOAD_DIR=./data/uploads
MEDIA_DIR=./data/media
MAX_UPLOAD_SIZE=524288000
MAX_UPLOAD_SIZE_MB=100

# ─── Database ─────────────────────────────────────────────────
# Paths para Docker (ajustar para dev local se necessário)
DATABASE_URL=sqlite+aiosqlite:///./data/whatsapp_insight.db

# ─── App ──────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=change-this-in-production-at-least-32-chars-long!!

# ─── JWT Authentication ──────────────────────────────────────
# OBRIGATÓRIO: Chave secreta para assinar tokens JWT (mínimo 32 caracteres)
JWT_SECRET_KEY=change-this-jwt-secret-in-production-min-32-chars!!
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ─── Admin User ──────────────────────────────────────────────
# OBRIGATÓRIO: Credenciais do usuário administrador
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password!!

# ─── Registration ────────────────────────────────────────────
# Permitir registro de novos usuários (true/false)
ALLOW_REGISTRATION=false

# ─── CORS (separado por vírgulas) ────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── Redis / Cache ────────────────────────────────────────────
# URL do Redis (deixe vazio para desabilitar cache)
REDIS_URL=redis://redis:6379/0
# TTL do cache em segundos (padrão: 86400 = 24h)
CACHE_TTL_SECONDS=86400
# Habilitar/desabilitar cache (true/false)
CACHE_ENABLED=true

# ─── Logging ──────────────────────────────────────────────────
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Formato de log: json (produção) ou console (desenvolvimento)
LOG_FORMAT=json
