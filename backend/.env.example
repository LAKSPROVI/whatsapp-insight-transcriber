# ─── API Keys ─────────────────────────────────────────────────
# Sua API Key da Anthropic (para Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# URL do proxy gameron (coletar dados locais e enviar para Claude)
# Padrão: http://localhost:1337 (gameron local)
ANTHROPIC_BASE_URL=http://localhost:1337

# ─── Claude Config ────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6
MAX_TOKENS=4096
TEMPERATURE=0.3

# ─── Agentes ──────────────────────────────────────────────────
MAX_AGENTS=20
AGENT_TIMEOUT=300

# ─── Armazenamento ────────────────────────────────────────────
UPLOAD_DIR=uploads
MEDIA_DIR=media
MAX_UPLOAD_SIZE=524288000

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./whatsapp_insight.db

# ─── App ──────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=change-this-in-production-at-least-32-chars-long!!

# ─── CORS (separado por vírgulas) ────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
